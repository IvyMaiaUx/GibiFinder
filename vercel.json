{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/gibi-finder/dist/public",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "framework": null,
  "functions": {
    "api/index.mjs": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/cron/refresh-catalog", "schedule": "0 */6 * * *" }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
