# Gibi Finder - Variáveis de Ambiente
# Renomeie ou configure este arquivo para ativar as integrações com Supabase e Gemini AI.

# Chave da API do Google Gemini (obtenha em https://aistudio.google.com)
GEMINI_API_KEY=

# Chave de Administração para o painel /admin (padrão se vazio: gibi-admin-2024)
ADMIN_KEY=gibi-admin-2024

# Configurações do Supabase (obtenha em https://supabase.com/dashboard)
SUPABASE_URL=
SUPABASE_ANON_KEY=
